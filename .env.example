# ── Payments (Circle x402 Gateway) ───────────────────────────────────────────
# The wallet address that receives reader payments. This is YOUR wallet —
# generate one in MetaMask and paste the address (0x...) here.
# No Circle console account needed. Payments are collected via Arc testnet.
SELLER_ADDRESS=

# ── OpenAI (GPT-4o pricing agent) ────────────────────────────────────────────
# Get from https://platform.openai.com → API Keys
OPENAI_API_KEY=

# ── Server ────────────────────────────────────────────────────────────────────
PORT=3001
SESSION_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:3001/api/auth/google/callback
