# ── Circle ────────────────────────────────────────────────────────────────────
# Get from https://console.circle.com → Developer → API Keys
CIRCLE_API_KEY=

# ── Anthropic (Claude API) ────────────────────────────────────────────────────
# Get from https://console.anthropic.com → API Keys
ANTHROPIC_API_KEY=

# ── Arc Blockchain ────────────────────────────────────────────────────────────
# Get from ARC CLI after running: arc testnet init
ARC_RPC_URL=

# ── Server ────────────────────────────────────────────────────────────────────
PORT=3001
